## YOUR SOLUTION HERE ##
def make_lag_df(df, feature_cols, window=24):
    out = {}
    for col in feature_cols:
        s = df[col]
        for lag in range(window, 0, -1):
            out[f"{col}_t-{lag}"] = s.shift(lag)
    df_seq = pd.DataFrame(out, index=df.index).dropna()
    return df_seq





## YOUR SOLUTION HERE ##
